---
interface Props {
    title?: string;
}

import '../styles/global.css';
const { title = 'orzxiety.ru' } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="theme-color" content="#155dfc" />
        <title>{title}</title>
        <link rel="icon" type="image/png" href="/favicon.png" />
        <meta name="description" content="A software developer" />
        <meta name="og:title" content="Orzxiety" />
        <meta name="og:description" content="A software developer" />
    </head>
    <body>
        <div class="min-h-dvh bg-neutral-900 p-8">
            <slot />
        </div>
    </body>
</html>
